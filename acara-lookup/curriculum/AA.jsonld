28-edd1540d037b"}],"http://www.w3.org/2004/02/skos/core#prefLabel":[{"@language":"en-au","@value":"AAK1"}]},{"@id":"http://vocabulary.curriculum.edu.au/MRAC/2024/04/CCP/AA/13b74d1d-00bf-455b-bd58-3771a287c550","@type":["http://purl.org/ASN/schema/core/Statement","http://www.w3.org/2004/02/skos/core#Concept"],"http://purl.org/ASN/schema/core/authorityStatus":[{"@id":"http://purl.org/ASN/scheme/ASNAuthorityStatus/Original"}],"http://purl.org/ASN/schema/core/indexingStatus":[{"@id":"http://purl.org/ASN/scheme/ASNIndexingStatus/No"}],"http://purl.org/ASN/schema/core/listID":[{"@language":"en-au","@value":"3"}],"http://purl.org/ASN/schema/core/statementLabel":[{"@language":"en-au","@value":"Set of organising ideas"}],"http://purl.org/ASN/schema/core/statementNotation":[{"@language":"en-au","@value":"AAG"}],"http://purl.org/dc/terms/description":[{"@language":"en-au","@value":"These organising ideas include the relationship-building contribution of Australians with Asian heritage and explore how active connections between young people and Asia’s diverse communities can be deepened and contribute to global citizenship. "}],"http://purl.org/dc/terms/modified":[{"@type":"http://www.w3.org/2001/XMLSchema#dateTime","@value":"2021-09-03T15:54:30.000Z"}],"http://purl.org/dc/terms/title":[{"@language":"en-au","@value":"Growing Asia-Australia engagement"}],"http://purl.org/gem/qualifiers/hasChild":[{"@id":"http://vocabulary.curriculum.edu.au/MRAC/2024/04/CCP/AA/c44ca798-515b-45c0-9bb3-88d95437c391"},{"@id":"http://vocabulary.curriculum.edu.au/MRAC/2024/04/CCP/AA/7ca01fdb-c66b-41a3-b772-46fba943966e"}],"http://purl.org/gem/qualifiers/isChildOf":[{"@id":"http://vocabulary.curriculum.edu.au/MRAC/2024/04/CCP/AA/d64018fa-ec43-4d57-b4a2-afd4336ba7ce"}],"http://www.w3.org/2004/02/skos/core#prefLabel":[{"@language":"en-au","@value":"AAG"}]},{"@id":"http://vocabulary.curriculum.edu.au/MRAC/2024/04/CCP/AA/443c9e36-19f6-408b-a984-99c0ff18fda9","@type":["http://purl.org/ASN/schema/core/Statement","http://www.w3.org/2004/02/skos/core#Concept"],"http://purl.org/ASN/schema/core/authorityStatus":[{"@id":"http://purl.org/ASN/scheme/ASNAuthorityStatus/Original"}],"http://purl.org/ASN/schema/core/conceptTerm":[{"@language":"en-au","@value":"SCIENCE_TEACHER_BACKGROUND_INFORMATION"}],"http://purl.org/ASN/schema/core/indexingStatus":[{"@id":"http://purl.org/ASN/scheme/ASNIndexingStatus/No"}],"http://purl.org/ASN/schema/core/statementLabel":[{"@language":"en-au","@value":"Organising Idea"}],"http://purl.org/ASN/schema/core/statementNotation":[{"@language":"en-au","@value":"AAK2"}],"http://purl.org/dc/terms/description":[{"@language":"en-au","@value":"The interrelationships between people and the diverse environments and systems across the Asia region have global implications. "}],"http://purl.org/dc/terms/modified":[{"@type":"http://www.w3.org/2001/XMLSchema#dateTime","@value":"2021-09-03T15:54:30.000Z"}],"http://purl.org/dc/terms/title":[{"@language":"en-au","@value":"The interrelationships between people and the diverse environments and systems across the Asia region have global implications. "}],"http://purl.org/gem/qualifiers/isChildOf":[{"@id":"http://vocabulary.curriculum.edu.au/MRAC/2024/04/CCP/AA/b7e0b1cf-96f9-4710-9928-edd1540d037b"}],"http://www.w3.org/2004/02/skos/core#prefLabel":[{"@language":"en-au","@value":"AAK2"}]},{"@id":"http://vocabulary.curriculum.edu.au/MRAC/2024/04/CCP/AA/665d9a7a-3b10-4f3a-a480-010ce6e1d22b","@type":["http://purl.org/ASN/schema/core/Statement","http://www.w3.org/2004/02/skos/core#Concept"],"http://purl.org/ASN/schema/core/authorityStatus":[{"@id":"http://purl.org/ASN/scheme/ASNAuthorityStatus/Original"}],"http://purl.org/ASN/schema/core/indexingStatus":[{"@id":"http://purl.org/ASN/scheme/ASNIndexingStatus/No"}],"http://purl.org/ASN/schema/core/listID":[{"@language":"en-au","@value":"2"}],"http://purl.org/ASN/schema/core/statementLabel":[{"@language":"en-au","@value":"Set of organising ideas"}],"http://purl.org/ASN/schema/core/statementNotation":[{"@language":"en-au","@value":"AAU"}],"http://purl.org/dc/terms/description":[{"@language":"en-au","@value":"These organising ideas examine the ways in which different significant nations in Asia have affected change and contributed to global developments. "}],"http://purl.org/dc/terms/modified":[{"@type":"http://www.w3.org/2001/XMLSchema#dateTime","@value":"2021-09-03T15:54:30.000Z"}],"http://purl.org/dc/terms/title":[{"@language":"en-au","@value":"Understanding Asia's global significance"}],"http://purl.org/gem/qualifiers/hasChild":[{"@id":"http://vocabulary.curriculum.edu.au/MRAC/2024/04/CCP/AA/66787a3c-bd1f-45f9-9aac-65ffe9bc3c5e"},{"@id":"http://vocabulary.curriculum.edu.au/MRAC/2024/04/CCP/AA/d6b64eae-08b7-411f-9ebf-fb829d491fa4"}],"http://purl.org/gem/qualifiers/isChildOf":[{"@id":"http://vocabulary.curriculum.edu.au/MRAC/2024/04/CCP/AA/d64018fa-ec43-4d57-b4a2-afd4336ba7ce"}],"http://www.w3.org/2004/02/skos/core#prefLabel":[{"@language":"en-au","@value":"AAU"}]},{"@id":"http://vocabulary.curriculum.edu.au/MRAC/2024/04/CCP/AA/66787a3c-bd1f-45f9-9aac-65ffe9bc3c5e","@type":["http://purl.org/ASN/schema/core/Statement","http://www.w3.org/2004/02/skos/core#Concept"],"http://purl.org/ASN/schema/core/authorityStatus":[{"@id":"http://purl.org/ASN/scheme/ASNAuthorityStatus/Original"}],"http://purl.org/ASN/schema/core/conceptTerm":[{"@language":"en-au","@value":"SCIENCE_TEACHER_BACKGROUND_INFORMATION"}],"http://purl.org/ASN/schema/core/indexingStatus":[{"@id":"http://purl.org/ASN/scheme/ASNIndexingStatus/No"}],"http://purl.org/ASN/schema/core/statementLabel":[{"@language":"en-au","@value":"Organising Idea"}],"http://purl.org/ASN/schema/core/statementNotation":[{"@language":"en-au","@value":"AAU1"}],"http://purl.org/dc/terms/description":[{"@language":"en-au","@value":"The nations of Asia influence historical and contemporary global relationships, including international responses to global developments and events."}],"http://purl.org/dc/terms/modified":[{"@type":"http://www.w3.org/2001/XMLSchema#dateTime","@value":"2021-09-03T15:54:30.000Z"}],"http://purl.org/dc/terms/title":[{"@language":"en-au","@value":"The nations of Asia influence historical and contemporary global relationships, including international responses to global developments and events."}],"http://purl.org/gem/qualifiers/isChildOf":[{"@id":"http://vocabulary.curriculum.edu.au/MRAC/2024/04/CCP/AA/665d9a7a-3b10-4f3a-a480-010ce6e1d22b"}],"http://www.w3.org/2004/02/skos/core#prefLabel":[{"@language":"en-au","@value":"AAU1"}]},{"@id":"http://vocabulary.curriculum.edu.au/MRAC/2024/04/CCP/AA/7ca01fdb-c66b-41a3-b772-46fba943966e","@type":["http://purl.org/ASN/schema/core/Statement","http://www.w3.org/2004/02/skos/core#Concept"],"http://purl.org/ASN/schema/core/authorityStatus":[{"@id":"http://purl.org/ASN/scheme/ASNAuthorityStatus/Original"}],"http://purl.org/ASN/schema/core/conceptTerm":[{"@language":"en-au","@value":"SCIENCE_TEACHER_BACKGROUND_INFORMATION"}],"http://purl.org/ASN/schema/core/indexingStatus":[{"@id":"http://purl.org/ASN/scheme/ASNIndexingStatus/No"}],"http://purl.org/ASN/schema/core/statementLabel":[{"@language":"en-au","@value":"Organising Idea"}],"http://purl.org/ASN/schema/core/statementNotation":[{"@language":"en-au","@value":"AAG2"}],"http://purl.org/dc/terms/description":[{"@language":"en-au","@value":"Australia and Asia are interdependent through a range of historical and contemporary connections."}],"http://purl.org/dc/terms/modified":[{"@type":"http://www.w3.org/2001/XMLSchema#dateTime","@value":"2021-09-03T15:54:30.000Z"}],"http://purl.org/dc/terms/title":[{"@language":"en-au","@value":"Australia and Asia are interdependent through a range of historical and contemporary connections."}],"http://purl.org/gem/qualifiers/isChildOf":[{"@id":"http://vocabulary.curriculum.edu.au/MRAC/2024/04/CCP/AA/13b74d1d-00bf-455b-bd58-3771a287c550"}],"http://www.w3.org/2004/02/skos/core#prefLabel":[{"@language":"en-au","@value":"AAG2"}]},{"@id":"http://vocabulary.curriculum.edu.au/MRAC/2024/04/CCP/AA/b7e0b1cf-96f9-4710-9928-edd1540d037b","@type":["http://purl.org/ASN/schema/core/Statement","http://www.w3.org/2004/02/skos/core#Concept"],"http://purl.org/ASN/schema/core/authorityStatus":[{"@id":"http://purl.org/ASN/scheme/ASNAuthorityStatus/Original"}],"http://purl.org/ASN/schema/core/indexingStatus":[{"@id":"http://purl.org/ASN/scheme/ASNIndexingStatus/No"}],"http://purl.org/ASN/schema/core/listID":[{"@language":"en-au","@value":"1"}],"http://purl.org/ASN/schema/core/statementLabel":[{"@language":"en-au","@value":"Set of organising ideas"}],"http://purl.org/ASN/schema/core/statementNotation":[{"@language":"en-au","@value":"AAK"}],"http://purl.org/dc/terms/description":[{"@language":"en-au","@value":"These organising ideas emphasise the need to appreciate the backgrounds, experiences, stories, religions, beliefs and perspectives within and among the nations of the Asia region and the interconnections with Australia. "}],"http://purl.org/dc/terms/modified":[{"@type":"http://www.w3.org/2001/XMLSchema#dateTime","@value":"2021-09-03T15:54:30.000Z"}],"http://purl.org/dc/terms/title":[{"@language":"en-au","@value":"Knowing Asia and its diversity"}],"http://purl.org/gem/qualifiers/hasChild":[{"@id":"http://vocabulary.curriculum.edu.au/MRAC/2024/04/CCP/AA/0a8ee105-c28c-46ea-bd8d-f6e70a730aa8"},{"@id":"http://vocabulary.curriculum.edu.au/MRAC/2024/04/CCP/AA/443c9e36-19f6-408b-a984-99c0ff18fda9"}],"http://purl.org/gem/qualifiers/isChildOf":[{"@id":"http://vocabulary.curriculum.edu.au/MRAC/2024/04/CCP/AA/d64018fa-ec43-4d57-b4a2-afd4336ba7ce"}],"http://www.w3.org/2004/02/skos/core#prefLabel":[{"@language":"en-au","@value":"AAK"}]},{"@id":"http://vocabulary.curriculum.edu.au/MRAC/2024/04/CCP/AA/c44ca798-515b-45c0-9bb3-88d95437c391","@type":["http://purl.org/ASN/schema/core/Statement","http://www.w3.org/2004/02/skos/core#Concept"],"http://purl.org/ASN/schema/core/authorityStatus":[{"@id":"http://purl.org/ASN/scheme/ASNAuthorityStatus/Original"}],"http://purl.org/ASN/schema/core/conceptTerm":[{"@language":"en-au","@value":"SCIENCE_TEACHER_BACKGROUND_INFORMATION"}],"http://purl.org/ASN/schema/core/indexingStatus":[{"@id":"http://purl.org/ASN/scheme/ASNIndexingStatus/No"}],"http://purl.org/ASN/schema/core/statementLabel":[{"@language":"en-au","@value":"Organising Idea"}],"http://purl.org/ASN/schema/core/statementNotation":[{"@language":"en-au","@value":"AAG1"}],"http://purl.org/dc/terms/description":[{"@language":"en-au","@value":"Australia’s developing and deepening relationships with the peoples of Asia influence both mutual understandings and expressions of citizenship and culture nationally, regionally and globally."}],"http://purl.org/dc/terms/modified":[{"@type":"http://www.w3.org/2001/XMLSchema#dateTime","@value":"2021-09-03T15:54:30.000Z"}],"http://purl.org/dc/terms/title":[{"@language":"en-au","@value":"Australia’s developing and deepening relationships with the peoples of Asia influence both mutual understandings and expressions of citizenship and culture nationally, regionally and globally."}],"http://purl.org/gem/qualifiers/isChildOf":[{"@id":"http://vocabulary.curriculum.edu.au/MRAC/2024/04/CCP/AA/13b74d1d-00bf-455b-bd58-3771a287c550"}],"http://www.w3.org/2004/02/skos/core#prefLabel":[{"@language":"en-au","@value":"AAG1"}]},{"@id":"http://vocabulary.curriculum.edu.au/MRAC/2024/04/CCP/AA/d64018fa-ec43-4d57-b4a2-afd4336ba7ce","@type":["http://purl.org/ASN/schema/core/Statement","http://www.w3.org/2004/02/skos/core#Concept"],"http://purl.org/ASN/schema/core/authorityStatus":[{"@id":"http://purl.org/ASN/scheme/ASNAuthorityStatus/Original"}],"http://purl.org/ASN/schema/core/indexingStatus":[{"@id":"http://purl.org/ASN/scheme/ASNIndexingStatus/No"}],"http://purl.org/ASN/schema/core/statementLabel":[{"@language":"en-au","@value":"Cross-Curriculum Priority"}],"http://purl.org/ASN/schema/core/statementNotation":[{"@language":"en-au","@value":"AA"}],"http://purl.org/dc/terms/description":[{"@language":"en-au","@value":"<p>The Asia region exerts significant influence globally and in Australia. Young Australians need to develop the knowledge, skills, capabilities and attitudes to effectively navigate and contribute to our regional neighbourhood.</p><p>Asia is our part of the world. Knowing, understanding and growing engagement with Asia are foundational for young people as Australia seeks to strengthen its ties in the Asia region.</p>"}],"http://purl.org/dc/terms/modified":[{"@type":"http://www.w3.org/2001/XMLSchema#dateTime","@value":"2021-09-03T15:54:30.000Z"}],"http://purl.org/dc/terms/title":[{"@language":"en-au","@value":"Asia and Australia's Engagement with Asia"}],"http://purl.org/gem/qualifiers/hasChild":[{"@id":"http://vocabulary.curriculum.edu.au/MRAC/2024/04/CCP/AA/b7e0b1cf-96f9-4710-9928-edd1540d037b"},{"@id":"http://vocabulary.curriculum.edu.au/MRAC/2024/04/CCP/AA/665d9a7a-3b10-4f3a-a480-010ce6e1d22b"},{"@id":"http://vocabulary.curriculum.edu.au/MRAC/2024/04/CCP/AA/13b74d1d-00bf-455b-bd58-3771a287c550"}],"http://purl.org/gem/qualifiers/isChildOf":[{"@id":"http://vocabulary.curriculum.edu.au/MRAC/2024/04/CCP/5c04d332-8412-4e26-bd57-425883be63aa"}],"http://www.w3.org/2004/02/skos/core#prefLabel":[{"@language":"en-au","@value":"AA"}]},{"@id":"http://vocabulary.curriculum.edu.au/MRAC/2024/04/CCP/AA/d6b64eae-08b7-411f-9ebf-fb829d491fa4","@type":["http://purl.org/ASN/schema/core/Statement","http://www.w3.org/2004/02/skos/core#Concept"],"http://purl.org/ASN/schema/core/authorityStatus":[{"@id":"http://purl.org/ASN/scheme/ASNAuthorityStatus/Original"}],"http://purl.org/ASN/schema/core/conceptTerm":[{"@language":"en-au","@value":"SCIENCE_TEACHER_BACKGROUND_INFORMATION"}],"http://purl.org/ASN/schema/core/indexingStatus":[{"@id":"http://purl.org/ASN/scheme/ASNIndexingStatus/No"}],"http://purl.org/ASN/schema/core/statementLabel":[{"@language":"en-au","@value":"Organising Idea"}],"http://purl.org/ASN/schema/core/statementNotation":[{"@language":"en-au","@value":"AAU2"}],"http://purl.org/dc/terms/description":[{"@language":"en-au","@value":"The peoples of Asia shape human endeavour through aesthetic, creative, political, sporting, economic, technological and scientific domains."}],"http://purl.org/dc/terms/modified":[{"@type":"http://www.w3.org/2001/XMLSchema#dateTime","@value":"2021-09-03T15:54:30.000Z"}],"http://purl.org/dc/terms/title":[{"@language":"en-au","@value":"The peoples of Asia shape human endeavour through aesthetic, creative, political, sporting, economic, technological and scientific domains."}],"http://purl.org/gem/qualifiers/isChildOf":[{"@id":"http://vocabulary.curriculum.edu.au/MRAC/2024/04/CCP/AA/665d9a7a-3b10-4f3a-a480-010ce6e1d22b"}],"http://www.w3.org/2004/02/skos/core#prefLabel":[{"@language":"en-au","@value":"AAU2"}]},{"@id":"http://www.w3.org/2004/02/skos/core","http://purl.org/dc/terms/contributor":[{"@id":"http://vocabulary.curriculum.edu.au/user/srichardson"}]},{"@id":"http://www.w3.org/2008/05/skos-xl","http://purl.org/dc/terms/contributor":[{"@id":"http://vocabulary.curriculum.edu.au/user/srichardson"}]}],"@id":"http://vocabulary.curriculum.edu.au/MRAC/2024/04/CCP/AA/thesaurus"}]