","@value":"SCIENCE_TEACHER_BACKGROUND_INFORMATION"}],"http://purl.org/ASN/schema/core/indexingStatus":[{"@id":"http://purl.org/ASN/scheme/ASNIndexingStatus/No"}],"http://purl.org/ASN/schema/core/statementLabel":[{"@language":"en-au","@value":"Organising Idea"}],"http://purl.org/ASN/schema/core/statementNotation":[{"@language":"en-au","@value":"SW1"}],"http://purl.org/dc/terms/description":[{"@language":"en-au","@value":"World views that recognise the interdependence of Earth’s systems, and value diversity, equity and social justice, are essential for achieving sustainability. "}],"http://purl.org/dc/terms/modified":[{"@type":"http://www.w3.org/2001/XMLSchema#dateTime","@value":"2021-09-03T15:54:30.000Z"}],"http://purl.org/dc/terms/title":[{"@language":"en-au","@value":"World views that recognise the interdependence of Earth’s systems, and value diversity, equity and social justice, are essential for achieving sustainability. "}],"http://purl.org/gem/qualifiers/isChildOf":[{"@id":"http://vocabulary.curriculum.edu.au/MRAC/2024/04/CCP/S/4dd68e82-c24e-48d2-8162-d0187ee4f626"}],"http://www.w3.org/2004/02/skos/core#prefLabel":[{"@language":"en-au","@value":"SW1"}]},{"@id":"http://vocabulary.curriculum.edu.au/MRAC/2024/04/CCP/S/c1827809-d8e2-4fdf-b688-8cee8c1d005f","@type":["http://purl.org/ASN/schema/core/Statement","http://www.w3.org/2004/02/skos/core#Concept"],"http://purl.org/ASN/schema/core/authorityStatus":[{"@id":"http://purl.org/ASN/scheme/ASNAuthorityStatus/Original"}],"http://purl.org/ASN/schema/core/conceptTerm":[{"@language":"en-au","@value":"SCIENCE_TEACHER_BACKGROUND_INFORMATION"}],"http://purl.org/ASN/schema/core/indexingStatus":[{"@id":"http://purl.org/ASN/scheme/ASNIndexingStatus/No"}],"http://purl.org/ASN/schema/core/statementLabel":[{"@language":"en-au","@value":"Organising Idea"}],"http://purl.org/ASN/schema/core/statementNotation":[{"@language":"en-au","@value":"SS1"}],"http://purl.org/dc/terms/description":[{"@language":"en-au","@value":"All life forms, including human life, are connected through Earth’s systems (geosphere, biosphere, hydrosphere and atmosphere) on which they depend for their wellbeing and survival."}],"http://purl.org/dc/terms/modified":[{"@type":"http://www.w3.org/2001/XMLSchema#dateTime","@value":"2021-09-03T15:54:30.000Z"}],"http://purl.org/dc/terms/title":[{"@language":"en-au","@value":"All life forms, including human life, are connected through Earth’s systems (geosphere, biosphere, hydrosphere and atmosphere) on which they depend for their wellbeing and survival."}],"http://purl.org/gem/qualifiers/isChildOf":[{"@id":"http://vocabulary.curriculum.edu.au/MRAC/2024/04/CCP/S/1d4d25c2-5175-4821-af7d-fe92b6d8ab55"}],"http://www.w3.org/2004/02/skos/core#prefLabel":[{"@language":"en-au","@value":"SS1"}]},{"@id":"http://vocabulary.curriculum.edu.au/MRAC/2024/04/CCP/S/ca42e013-5157-4233-a8ba-ad534d8183fa","@type":["http://purl.org/ASN/schema/core/Statement","http://www.w3.org/2004/02/skos/core#Concept"],"http://purl.org/ASN/schema/core/authorityStatus":[{"@id":"http://purl.org/ASN/scheme/ASNAuthorityStatus/Original"}],"http://purl.org/ASN/schema/core/conceptTerm":[{"@language":"en-au","@value":"SCIENCE_TEACHER_BACKGROUND_INFORMATION"}],"http://purl.org/ASN/schema/core/indexingStatus":[{"@id":"http://purl.org/ASN/scheme/ASNIndexingStatus/No"}],"http://purl.org/ASN/schema/core/statementLabel":[{"@language":"en-au","@value":"Organising Idea"}],"http://purl.org/ASN/schema/core/statementNotation":[{"@language":"en-au","@value":"SD2"}],"http://purl.org/dc/terms/description":[{"@language":"en-au","@value":"Creative and innovative design is integral to the identification of new ways of sustainable living."}],"http://purl.org/dc/terms/modified":[{"@type":"http://www.w3.org/2001/XMLSchema#dateTime","@value":"2021-09-03T15:54:30.000Z"}],"http://purl.org/dc/terms/title":[{"@language":"en-au","@value":"Creative and innovative design is integral to the identification of new ways of sustainable living."}],"http://purl.org/gem/qualifiers/isChildOf":[{"@id":"http://vocabulary.curriculum.edu.au/MRAC/2024/04/CCP/S/dc42d3b1-28f5-4797-b215-ba1c4a535d0c"}],"http://www.w3.org/2004/02/skos/core#prefLabel":[{"@language":"en-au","@value":"SD2"}]},{"@id":"http://vocabulary.curriculum.edu.au/MRAC/2024/04/CCP/S/d5c09ccd-b350-416d-be3e-bef864c4bf2e","@type":["http://purl.org/ASN/schema/core/Statement","http://www.w3.org/2004/02/skos/core#Concept"],"http://purl.org/ASN/schema/core/authorityStatus":[{"@id":"http://purl.org/ASN/scheme/ASNAuthorityStatus/Original"}],"http://purl.org/ASN/schema/core/conceptTerm":[{"@language":"en-au","@value":"SCIENCE_TEACHER_BACKGROUND_INFORMATION"}],"http://purl.org/ASN/schema/core/indexingStatus":[{"@id":"http://purl.org/ASN/scheme/ASNIndexingStatus/No"}],"http://purl.org/ASN/schema/core/statementLabel":[{"@language":"en-au","@value":"Organising Idea"}],"http://purl.org/ASN/schema/core/statementNotation":[{"@language":"en-au","@value":"SS3"}],"http://purl.org/dc/terms/description":[{"@language":"en-au","@value":"Social, economic and political systems influence the sustainability of Earth’s systems. "}],"http://purl.org/dc/terms/modified":[{"@type":"http://www.w3.org/2001/XMLSchema#dateTime","@value":"2021-09-03T15:54:30.000Z"}],"http://purl.org/dc/terms/title":[{"@language":"en-au","@value":"Social, economic and political systems influence the sustainability of Earth’s systems. "}],"http://purl.org/gem/qualifiers/isChildOf":[{"@id":"http://vocabulary.curriculum.edu.au/MRAC/2024/04/CCP/S/1d4d25c2-5175-4821-af7d-fe92b6d8ab55"}],"http://www.w3.org/2004/02/skos/core#prefLabel":[{"@language":"en-au","@value":"SS3"}]},{"@id":"http://vocabulary.curriculum.edu.au/MRAC/2024/04/CCP/S/dc42d3b1-28f5-4797-b215-ba1c4a535d0c","@type":["http://purl.org/ASN/schema/core/Statement","http://www.w3.org/2004/02/skos/core#Concept"],"http://purl.org/ASN/schema/core/authorityStatus":[{"@id":"http://purl.org/ASN/scheme/ASNAuthorityStatus/Original"}],"http://purl.org/ASN/schema/core/indexingStatus":[{"@id":"http://purl.org/ASN/scheme/ASNIndexingStatus/No"}],"http://purl.org/ASN/schema/core/listID":[{"@language":"en-au","@value":"3"}],"http://purl.org/ASN/schema/core/statementLabel":[{"@language":"en-au","@value":"Set of organising ideas"}],"http://purl.org/ASN/schema/core/statementNotation":[{"@language":"en-au","@value":"SD"}],"http://purl.org/dc/terms/description":[{"@language":"en-au","@value":"These organising ideas address the role of innovation and creativity in sustainably designed solutions, including products, environments and services, that aim to reduce present and future impacts or to restore the health or diversity of environmental, social and economic systems.  "}],"http://purl.org/dc/terms/modified":[{"@type":"http://www.w3.org/2001/XMLSchema#dateTime","@value":"2021-09-03T15:54:30.000Z"}],"http://purl.org/dc/terms/title":[{"@language":"en-au","@value":"Design"}],"http://purl.org/gem/qualifiers/hasChild":[{"@id":"http://vocabulary.curriculum.edu.au/MRAC/2024/04/CCP/S/7dc7ef2d-635d-4ecc-bc89-c9c1055024ed"},{"@id":"http://vocabulary.curriculum.edu.au/MRAC/2024/04/CCP/S/ca42e013-5157-4233-a8ba-ad534d8183fa"},{"@id":"http://vocabulary.curriculum.edu.au/MRAC/2024/04/CCP/S/b997c5e4-7f4d-4ffc-af5b-7222318165b2"}],"http://purl.org/gem/qualifiers/isChildOf":[{"@id":"http://vocabulary.curriculum.edu.au/MRAC/2024/04/CCP/S/dd4eecc4-ffac-4ecb-bea0-8e51d2570eac"}],"http://www.w3.org/2004/02/skos/core#prefLabel":[{"@language":"en-au","@value":"SD"}]},{"@id":"http://vocabulary.curriculum.edu.au/MRAC/2024/04/CCP/S/dd4eecc4-ffac-4ecb-bea0-8e51d2570eac","@type":["http://purl.org/ASN/schema/core/Statement","http://www.w3.org/2004/02/skos/core#Concept"],"http://purl.org/ASN/schema/core/authorityStatus":[{"@id":"http://purl.org/ASN/scheme/ASNAuthorityStatus/Original"}],"http://purl.org/ASN/schema/core/indexingStatus":[{"@id":"http://purl.org/ASN/scheme/ASNIndexingStatus/No"}],"http://purl.org/ASN/schema/core/statementLabel":[{"@language":"en-au","@value":"Cross-Curriculum Priority"}],"http://purl.org/ASN/schema/core/statementNotation":[{"@language":"en-au","@value":"S"}],"http://purl.org/dc/terms/description":[{"@language":"en-au","@value":"<p>Sustainability addresses the ongoing capacity of Earth to maintain all life. Sustainable patterns of living seek to meet the needs of the present generation without compromising the needs of future generations.  </p><p> The Sustainability cross-curriculum priority explores the knowledge, skills, values and world views necessary for people to act in ways that contribute to a sustainable future. Designing solutions and actions for a sustainable future requires an understanding of the ways environmental, social and economic systems interact, and an ability to make balanced judgements based on present and future impacts. </p>"}],"http://purl.org/dc/terms/modified":[{"@type":"http://www.w3.org/2001/XMLSchema#dateTime","@value":"2021-09-03T15:54:30.000Z"}],"http://purl.org/dc/terms/title":[{"@language":"en-au","@value":"Sustainability"}],"http://purl.org/gem/qualifiers/hasChild":[{"@id":"http://vocabulary.curriculum.edu.au/MRAC/2024/04/CCP/S/1d4d25c2-5175-4821-af7d-fe92b6d8ab55"},{"@id":"http://vocabulary.curriculum.edu.au/MRAC/2024/04/CCP/S/4dd68e82-c24e-48d2-8162-d0187ee4f626"},{"@id":"http://vocabulary.curriculum.edu.au/MRAC/2024/04/CCP/S/dc42d3b1-28f5-4797-b215-ba1c4a535d0c"},{"@id":"http://vocabulary.curriculum.edu.au/MRAC/2024/04/CCP/S/ee8fb1bf-fc43-438f-a77b-4f4ae1f87bfe"}],"http://purl.org/gem/qualifiers/isChildOf":[{"@id":"http://vocabulary.curriculum.edu.au/MRAC/2024/04/CCP/5c04d332-8412-4e26-bd57-425883be63aa"}],"http://www.w3.org/2004/02/skos/core#prefLabel":[{"@language":"en-au","@value":"S"}]},{"@id":"http://vocabulary.curriculum.edu.au/MRAC/2024/04/CCP/S/ee8fb1bf-fc43-438f-a77b-4f4ae1f87bfe","@type":["http://purl.org/ASN/schema/core/Statement","http://www.w3.org/2004/02/skos/core#Concept"],"http://purl.org/ASN/schema/core/authorityStatus":[{"@id":"http://purl.org/ASN/scheme/ASNAuthorityStatus/Original"}],"http://purl.org/ASN/schema/core/indexingStatus":[{"@id":"http://purl.org/ASN/scheme/ASNIndexingStatus/No"}],"http://purl.org/ASN/schema/core/listID":[{"@language":"en-au","@value":"4"}],"http://purl.org/ASN/schema/core/statementLabel":[{"@language":"en-au","@value":"Set of organising ideas"}],"http://purl.org/ASN/schema/core/statementNotation":[{"@language":"en-au","@value":"SF"}],"http://purl.org/dc/terms/description":[{"@language":"en-au","@value":"These organising ideas address ways of thinking and acting that seek to empower young people to design action that will lead to an equitable, sustainable and inclusive future.  "}],"http://purl.org/dc/terms/modified":[{"@type":"http://www.w3.org/2001/XMLSchema#dateTime","@value":"2021-09-03T15:54:30.000Z"}],"http://purl.org/dc/terms/title":[{"@language":"en-au","@value":"Futures"}],"http://purl.org/gem/qualifiers/hasChild":[{"@id":"http://vocabulary.curriculum.edu.au/MRAC/2024/04/CCP/S/1ed94bf9-24b3-4af1-a758-351cb26cc8d1"},{"@id":"http://vocabulary.curriculum.edu.au/MRAC/2024/04/CCP/S/09066dd4-5067-41c6-8b7b-4d76ec1d38f0"}],"http://purl.org/gem/qualifiers/isChildOf":[{"@id":"http://vocabulary.curriculum.edu.au/MRAC/2024/04/CCP/S/dd4eecc4-ffac-4ecb-bea0-8e51d2570eac"}],"http://www.w3.org/2004/02/skos/core#prefLabel":[{"@language":"en-au","@value":"SF"}]},{"@id":"http://www.w3.org/2004/02/skos/core","http://purl.org/dc/terms/contributor":[{"@id":"http://vocabulary.curriculum.edu.au/user/srichardson"}]},{"@id":"http://www.w3.org/2008/05/skos-xl","http://purl.org/dc/terms/contributor":[{"@id":"http://vocabulary.curriculum.edu.au/user/srichardson"}]}],"@id":"http://vocabulary.curriculum.edu.au/MRAC/2024/04/CCP/S/thesaurus"}]