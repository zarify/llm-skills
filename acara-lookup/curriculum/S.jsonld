rg/ASN/schema/core/indexingStatus":[{"@id":"http://purl.org/ASN/scheme/ASNIndexingStatus/No"}],"http://purl.org/ASN/schema/core/listID":[{"@language":"en-au","@value":"2"}],"http://purl.org/ASN/schema/core/statementLabel":[{"@language":"en-au","@value":"Set of organising ideas"}],"http://purl.org/ASN/schema/core/statementNotation":[{"@language":"en-au","@value":"SW"}],"http://purl.org/dc/terms/description":[{"@language":"en-au","@value":"These organising ideas address the role of world views (sets of attitudes, values and beliefs) that shape individual and community ideas about how the world works and our role in the world. "}],"http://purl.org/dc/terms/modified":[{"@type":"http://www.w3.org/2001/XMLSchema#dateTime","@value":"2021-09-03T15:54:30.000Z"}],"http://purl.org/dc/terms/title":[{"@language":"en-au","@value":"World views"}],"http://purl.org/gem/qualifiers/hasChild":[{"@id":"http://vocabulary.curriculum.edu.au/MRAC/2024/04/CCP/S/bc7f7698-b14b-4396-be50-e95d6ff307ab"},{"@id":"http://vocabulary.curriculum.edu.au/MRAC/2024/04/CCP/S/82f7a616-9cb5-4a44-92cc-ad78bec27115"}],"http://purl.org/gem/qualifiers/isChildOf":[{"@id":"http://vocabulary.curriculum.edu.au/MRAC/2024/04/CCP/S/dd4eecc4-ffac-4ecb-bea0-8e51d2570eac"}],"http://www.w3.org/2004/02/skos/core#prefLabel":[{"@language":"en-au","@value":"SW"}]},{"@id":"http://vocabulary.curriculum.edu.au/MRAC/2024/04/CCP/S/7dc7ef2d-635d-4ecc-bc89-c9c1055024ed","@type":["http://purl.org/ASN/schema/core/Statement","http://www.w3.org/2004/02/skos/core#Concept"],"http://purl.org/ASN/schema/core/authorityStatus":[{"@id":"http://purl.org/ASN/scheme/ASNAuthorityStatus/Original"}],"http://purl.org/ASN/schema/core/conceptTerm":[{"@language":"en-au","@value":"SCIENCE_TEACHER_BACKGROUND_INFORMATION"}],"http://purl.org/ASN/schema/core/indexingStatus":[{"@id":"http://purl.org/ASN/scheme/ASNIndexingStatus/No"}],"http://purl.org/ASN/schema/core/statementLabel":[{"@language":"en-au","@value":"Organising Idea"}],"http://purl.org/ASN/schema/core/statementNotation":[{"@language":"en-au","@value":"SD1"}],"http://purl.org/dc/terms/description":[{"@language":"en-au","@value":"Sustainably designed products, environments and services aim to minimise the impact on or restore the quality and diversity of environmental, social and economic systems."}],"http://purl.org/dc/terms/modified":[{"@type":"http://www.w3.org/2001/XMLSchema#dateTime","@value":"2021-09-03T15:54:30.000Z"}],"http://purl.org/dc/terms/title":[{"@language":"en-au","@value":"Sustainably designed products, environments and services aim to minimise the impact on or restore the quality and diversity of environmental, social and economic systems."}],"http://purl.org/gem/qualifiers/isChildOf":[{"@id":"http://vocabulary.curriculum.edu.au/MRAC/2024/04/CCP/S/dc42d3b1-28f5-4797-b215-ba1c4a535d0c"}],"http://www.w3.org/2004/02/skos/core#prefLabel":[{"@language":"en-au","@value":"SD1"}]},{"@id":"http://vocabulary.curriculum.edu.au/MRAC/2024/04/CCP/S/82f7a616-9cb5-4a44-92cc-ad78bec27115","@type":["http://purl.org/ASN/schema/core/Statement","http://www.w3.org/2004/02/skos/core#Concept"],"http://purl.org/ASN/schema/core/authorityStatus":[{"@id":"http://purl.org/ASN/scheme/ASNAuthorityStatus/Original"}],"http://purl.org/ASN/schema/core/indexingStatus":[{"@id":"http://purl.org/ASN/scheme/ASNIndexingStatus/No"}],"http://purl.org/ASN/schema/core/statementLabel":[{"@language":"en-au","@value":"Organising Idea"}],"http://purl.org/ASN/schema/core/statementNotation":[{"@language":"en-au","@value":"SW2"}],"http://purl.org/dc/terms/description":[{"@language":"en-au","@value":"World views are formed by experiences at personal, local, national and global levels, and are linked to individual, community, business and political actions for sustainability. "}],"http://purl.org/dc/terms/modified":[{"@type":"http://www.w3.org/2001/XMLSchema#dateTime","@value":"2021-09-03T15:54:30.000Z"}],"http://purl.org/dc/terms/title":[{"@language":"en-au","@value":"World views are formed by experiences at personal, local, national and global levels, and are linked to individual, community, business and political actions for sustainability. "}],"http://purl.org/gem/qualifiers/isChildOf":[{"@id":"http://vocabulary.curriculum.edu.au/MRAC/2024/04/CCP/S/4dd68e82-c24e-48d2-8162-d0187ee4f626"}],"http://www.w3.org/2004/02/skos/core#prefLabel":[{"@language":"en-au","@value":"SW2"}]},{"@id":"http://vocabulary.curriculum.edu.au/MRAC/2024/04/CCP/S/afbd87b9-f44c-46bd-835b-32c8e338ca90","@type":["http://purl.org/ASN/schema/core/Statement","http://www.w3.org/2004/02/skos/core#Concept"],"http://purl.org/ASN/schema/core/authorityStatus":[{"@id":"http://purl.org/ASN/scheme/ASNAuthorityStatus/Original"}],"http://purl.org/ASN/schema/core/conceptTerm":[{"@language":"en-au","@value":"SCIENCE_TEACHER_BACKGROUND_INFORMATION"}],"http://purl.org/ASN/schema/core/indexingStatus":[{"@id":"http://purl.org/ASN/scheme/ASNIndexingStatus/No"}],"http://purl.org/ASN/schema/core/statementLabel":[{"@language":"en-au","@value":"Organising Idea"}],"http://purl.org/ASN/schema/core/statementNotation":[{"@language":"en-au","@value":"SS2"}],"http://purl.org/dc/terms/description":[{"@language":"en-au","@value":"Sustainable patterns of living require the responsible use of resources, maintenance of clean air, water and soils, and preservation or restoration of healthy environments. "}],"http://purl.org/dc/terms/modified":[{"@type":"http://www.w3.org/2001/XMLSchema#dateTime","@value":"2021-09-03T15:54:30.000Z"}],"http://purl.org/dc/terms/title":[{"@language":"en-au","@value":"Sustainable patterns of living require the responsible use of resources, maintenance of clean air, water and soils, and preservation or restoration of healthy environments. "}],"http://purl.org/gem/qualifiers/isChildOf":[{"@id":"http://vocabulary.curriculum.edu.au/MRAC/2024/04/CCP/S/1d4d25c2-5175-4821-af7d-fe92b6d8ab55"}],"http://www.w3.org/2004/02/skos/core#prefLabel":[{"@language":"en-au","@value":"SS2"}]},{"@id":"http://vo