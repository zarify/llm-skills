[{"@graph":[{"@id":"http://vocabulary.curriculum.edu.au/MRAC/2024/04/19679b09-cfba-4cd0-a02e-366ace2f3d83","@type":["http://purl.org/ASN/schema/core/Statement","http://www.w3.org/2004/02/skos/core#Concept"],"http://purl.org/ASN/schema/core/authorityStatus":[{"@id":"http://purl.org/ASN/scheme/ASNAuthorityStatus/Original"}],"http://purl.org/ASN/schema/core/indexingStatus":[{"@id":"http://purl.org/ASN/scheme/ASNIndexingStatus/No"}],"http://purl.org/ASN/schema/core/statementNotation":[{"@language":"en-au","@value":"root"}],"http://purl.org/dc/terms/description":[{"@language":"en-au","@value":"Corrected html tags"}],"http://purl.org/dc/terms/modified":[{"@type":"http://www.w3.org/2001/XMLSchema#dateTime","@value":"2024-04-22T01:16:51.365Z"}],"http://purl.org/dc/terms/rights":[{"@language":"en-au","@value":"©Copyright Australian Curriculum, Assessment and Reporting Authority"}],"http://purl.org/dc/terms/rightsHolder":[{"@language":"en-au","@value":"Australian Curriculum, Assessment and Reporting Authority"}],"http://purl.org/dc/terms/title":[{"@language":"en-au","@value":"Corrected html tags"}],"http://purl.org/gem/qualifiers/hasChild":[{"@id":"http://vocabulary.curriculum.edu.au/MRAC/2024/04/CCP/5c04d332-8412-4e26-bd57-425883be63aa"}],"http://www.w3.org/2004/02/skos/core#prefLabel":[{"@language":"en-au","@value":"root"}]},{"@id":"http://vocabulary.curriculum.edu.au/MRAC/2024/04/CCP/5c04d332-8412-4e26-bd57-425883be63aa","@type":["http://purl.org/ASN/schema/core/Statement","http://www.w3.org/2004/02/skos/core#Concept"],"http://purl.org/ASN/schema/core/authorityStatus":[{"@id":"http://purl.org/ASN/scheme/ASNAuthorityStatus/Original"}],"http://purl.org/ASN/schema/core/indexingStatus":[{"@id":"http://purl.org/ASN/scheme/ASNIndexingStatus/No"}],"http://purl.org/ASN/schema/core/listID":[{"@language":"en-au","@value":"3"}],"http://purl.org/ASN/schema/core/statementNotation":[{"@language":"en-au","@value":"CCP"}],"http://purl.org/dc/terms/description":[{"@language":"en-au","@value":"Cross-curriculum Priorities"}],"http://purl.org/dc/terms/modified":[{"@type":"http://www.w3.org/2001/XMLSchema#dateTime","@value":"2021-09-03T15:54:30.000Z"}],"http://purl.org/dc/terms/title":[{"@language":"en-au","@value":"Cross-curriculum Priorities"}],"http://purl.org/gem/qualifiers/hasChild":[{"@id":"http://vocabulary.curriculum.edu.au/MRAC/2024/04/CCP/A_TSI/f84c84ea-02a6-42c2-8c97-66f527855587"}],"http://purl.org/gem/qualifiers/isChildOf":[{"@id":"http://vocabulary.curriculum.edu.au/MRAC/2024/04/19679b09-cfba-4cd0-a02e-366ace2f3d83"}],"http://www.w3.org/2004/02/skos/core#prefLabel":[{"@language":"en-au","@value":"CCP"}]},{"@id":"http://vocabulary.curriculum.edu.au/MRAC/2024/04/CCP/A_TSI/119a4f3c-5dd2-4248-b35c-9310080b8f8b","@type":["http://purl.org/ASN/schema/core/Statement","http://www.w3.org/2004/02/skos/core#Concept"],"http://purl.org/ASN/schema/core/authorityStatus":[{"@id":"http://purl.org/ASN/scheme/ASNAuthorityStatus/Original"}],"http://purl.org/ASN/schema/core/conceptTerm":[{"@language":"en-au","@value":"SCIENCE_TEACHER_BACKGROUND_INFORMATION"}],"http://purl.org/ASN/schema/core/indexingStatus":[{"@id":"http://purl.org/ASN/scheme/ASNIndexingStatus/No"}],"http://purl.org/ASN/schema/core/statementLabel":[{"@language":"en-au","@value":"Organising Idea"}],"http://purl.org/ASN/schema/core/statementNotation":[{"@language":"en-au","@value":"A_TSIC3"}],"http://purl.org/dc/terms/description":[{"@language":"en-au","@value":"The First Peoples of Australia (Aboriginal Peoples) belong to the world’s oldest continuous cultures. First Nations Australians demonstrate resilience in the maintenance, practice and revitalisation of culture despite the many historic and enduring impacts of colonisation, and continue to celebrate and share the past, present and future manifestations of their cultures."}],"http://purl.org/dc/terms/modified":[{"@type":"http://www.w3.org/2001/XMLSchema#dateTime","@value":"2021-09-03T15:54:30.000Z"}],"http://purl.org/dc/terms/title":[{"@language":"en-au","@value":"The First Peoples of Australia (Aboriginal Peoples) belong to the world’s oldest continuous cultures. First Nations Australians demonstrate resilience in the maintenance, practice and revitalisation of culture despite the many historic and enduring impacts of colonisation, and continue to celebrate and share the past, present and future manifestations of their cultures."}],"http://purl.org/gem/qualifiers/isChildOf":[{"@id":"http://vocabulary.curriculum.edu.au/MRAC/2024/04/CCP/A_TSI/a6a830c6-102b-4325-8c1e-7dd3552b983c"}],"http://www.w3.org/2004/02/skos/core#prefLabel":[{"@language":"en-au","@value":"A_TSIC3"}]},{"@id":"http://vocabulary.curriculum.edu.au/MRAC/2024/04/CCP/A_TSI/14284281-58d4-43c6-9195-ae4a00a59cdf","@type":["http://purl.org/ASN/schema/core/Statement","http://www.w3.org/2004/02/skos/core#Concept"],"http://purl.org/ASN/schema/core/authorityStatus":[{"@id":"http://purl.org/ASN/scheme/ASNAuthorityStatus/Original"}],"http://purl.org/ASN/schema/core/indexingStatus":[{"@id":"http://purl.org/ASN/scheme/ASNIndexingStatus/No"}],"http://purl.org/ASN/schema/core/listID":[{"@language":"en-au","@value":"1"}],"http://purl.org/ASN/schema/core/statementLabel":[{"@language":"en-au","@value":"Set of organising ideas"}],"http://purl.org/ASN/schema/core/statementNotation":[{"@language":"en-au","@value":"A_TSICP"}],"http://purl.org/dc/terms/description":[{"@language":"en-au","@value":"These organising ideas recognise the special connection of First Nations Australians to Country/Place and acknowledge the impacts of colonisation on their ownership of, and access to, Country/Place."}],"http://purl.org/dc/terms/modified":[{"@type":"http://www.w3.org/2001/XMLSchema#dateTime","@value":"2021-09-03T15:54:30.000Z"}],"http://purl.org/dc/terms/title":[{"@language":"en-au","@value":"Country/Place"}],"http://purl.org/gem/qualifiers/hasChild":[{"@id":"http://vocabulary.curriculum.edu.au/MRAC/2024/04/CCP/A_TSI/f8d4a191-c790-4ff8-b203-2427a21d0b9a"},{"@id":"http://vocabulary.curriculum.edu.au/MRAC/2024/04/CCP/A_TSI/725a84d5-de92-432c-8d02-3b655813131d"},{"@id":"http://vocabulary.curriculum.edu.au/MRAC/2024/04/CCP/A_TSI/d7a08fd7-9924-4e01-875f-6ae08cc4674d"}],"http://purl.org/gem/qualifiers/isChildOf":[{"@id":"http://vocabulary.curriculum.edu.au/MRAC/2024/04/CCP/A_TSI/f84c84ea-02a6-42c2-8c97-66f527855587"}],"http://www.w3.org/2004/02/skos/core#prefLabel":[{"@language":"en-au","@value":"A_TSICP"}]},{"@id":"http://vocabulary.curriculum.edu.au/MRAC/2024/04/CCP/A_TSI/48c4c1a1-d829-4664-8065-81098c789148","@type":["http://purl.org/ASN/schema/core/Statement","http://www.w3.org/2004/02/skos/core#Concept"],"http://purl.org/ASN/schema/core/authorityStatus":[{"@id":"http://purl.org/ASN/scheme/ASNAuthorityStatus/Original"}],"http://purl.org/ASN/schema/core/indexingStatus":[{"@id":"http://purl.org/ASN/scheme/ASNIndexingStatus/No"}],"http://purl.org/ASN/schema/core/listID":[{"@language":"en-au","@value":"3"}],"http://purl.org/ASN/schema/core/statementLabel":[{"@language":"en-au","@value":"Set of organising ideas"}],"http://purl.org/ASN/schema/core/statementNotation":[{"@language":"en-au","@value":"A_TSIP"}],"http://purl.org/dc/terms/description":[{"@language":"en-au","@value":"These organising ideas recognise that Australia has 2 distinct First Nations Peoples, each encompassing a diversity of nations and peoples, and examine the significant contributions of First Nations Australians histories and cultures on a local, national and global scale."}],"http://purl.org/dc/terms/modified":[{"@type":"http://www.w3.org/2001/XMLSchema#dateTime","@value":"2021-09-03T15:54:30.000Z"}],"http://purl.org/dc/terms/title":[{"@language":"en-au","@value":"People"}],"http://purl.org/gem/qualifiers/hasChild":[{"@id":"http://vocabulary.curriculum.edu.au/MRAC/2024/04/CCP/A_TSI/940cfe04-48e5-475b-a682-94cb6c6b2235"},{"@id":"http://vocabulary.curriculum.edu.au/MRAC/2024/04/CCP/A_TSI/958b0a03-070f-4f61-af60-36b5172ae4f2"},{"@id":"http://vocabulary.curriculum.edu.au/MRAC/2024/04/CCP/A_TSI/62558d29-5510-4bf5-a4cb-afc390bf4dac"}],"http://purl.org/gem/qualifiers/isChildOf":[{"@id":"http://vocabulary.curriculum.edu.au/MRAC/2024/04/CCP/A_TSI/f84c84ea-02a6-42c2-8c97-66f527855587"}],"http://www.w3.org/2004/02/skos/core#prefLabel":[{"@language":"en-au","@value":"A_TSIP"}]},{"@id":"http://vocabulary.curriculum.edu.au/MRAC/2024/04/CCP/A_TSI/62558d29-5510-4bf5-a4cb-afc390bf4dac","@type":["http://purl.org/ASN/schema/core/Statement","http://www.w3.org/2004/02/skos/core#Concept"],"http://purl.org/ASN/schema/core/authorityStatus":[{"@id":"http://purl.org/ASN/scheme/ASNAuthorityStatus/Original"}],"http://purl.org/ASN/schema/core/conceptTerm":[{"@language":"en-au","@value":"SCIENCE_TEACHER_BACKGROUND_INFORMATION"}],"http://purl.org/ASN/schema/core/indexingStatus":[{"@id":"http://purl.org/ASN/scheme/ASNIndexingStatus/No"}],"http://purl.org/ASN/schema/core/statementLabel":[{"@language":"en-au","@value":"Organising Idea"}],"http://purl.org/ASN/schema/core/statementNotation":[{"@language":"en-au","@value":"A_TSIP3"}],"http://purl.org/dc/terms/description":[{"@language":"en-au","@value":"The significant and ongoing contributions of First Nations Australians and their histories and cultures are acknowledged locally, nationally and globally. "}],"http://purl.org/dc/terms/modified":[{"@type":"http://www.w3.org/2001/XMLSchema#dateTime","@value":"2021-09-03T15:54:30.000Z"}],"http://purl.org/dc/terms/title":[{"@language":"en-au","@value":"The significant and ongoing contributions of First Nations Australians and their histories and cultures are acknowledged locally, nationally and globally. "}],"http://purl.org/gem/qualifiers/isChildOf":[{"@id":"http://vocabulary.curriculum.edu.au/MRAC/2024/04/CCP/A_TSI/48c4c1a1-d829-4664-8065-81098c789148"}],"http://www.w3.org/2004/02/skos/core#prefLabel":[{"@language":"en-au","@value":"A_TSIP3"}]},{"@id":"http://vocabulary.curriculum.edu.au/MRAC/2024/04/CCP/A_TSI/646e98e2-6711-4331-a503-d664524421bf","@type":["http://purl.org/ASN/schema/core/Statement","http://www.w3.org/2004/02/skos/core#Concept"],"http://purl.org/ASN/schema/core/authorityStatus":[{"@id":"http://purl.org/ASN/scheme/ASNAuthorityStatus/Original"}],"http://purl.org/ASN/schema/core/conceptTerm":[{"@language":"en-au","@value":"SCIENCE_TEACHER_BACKGROUND_INFORMATION"}],"http://purl.org/ASN/schema/core/indexingStatus":[{"@id":"http://purl.org/ASN/scheme/ASNIndexingStatus/No"}],"http://purl.org/ASN/schema/core/statementLabel":[{"@language":"en-au","@value":"Organising Idea"}],"http://purl.org/ASN/schema/core/statementNotation":[{"@language":"en-au","@value":"A_TSIC2"}],"http://purl.org/dc/terms/description":[{"@language":"en-au","@value":"First Nations Australians’ ways of life reflect unique ways of being, knowing, thinking and doing."}],"http://purl.org/dc/terms/modified":[{"@type":"http://www.w3.org/2001/XMLSchema#dateTime","@value":"2021-09-03T15:54:30.000Z"}],"http://purl.org/dc/terms/title":[{"@language":"en-au","@value":"First Nations Australians’ ways of life reflect unique ways of being, knowing, thinking and doing."}],"http://purl.org/gem/qualifiers/isChildOf":[{"@id":"http://vocabulary.curriculum.edu.au/MRAC/2024/04/CCP/A_TSI/a6a830c6-102b-4325-8c1e-7dd3552b983c"}],"http://www.w3.org/2004/02/skos/core#prefLabel":[{"@language":"en-au","@value":"A_TSIC2"}]},{"@id":"http://vocabulary.curriculum.edu.au/MRAC/2024/04/CCP/A_TSI/725a84d5-de92-432c-8d02-3b655813131d","@type":["http://purl.org/ASN/schema/core/Statement","http://www.w3.org/2004/02/skos/core#Concept"],"http://purl.org/ASN/schema/core/authorityStatus":[{"@id":"http://purl.org/ASN/scheme/ASNAuthorityStatus/Original"}],"http://purl.org/ASN/schema/core/indexingStatus":[{"@id":"http://purl.org/ASN/scheme/ASNIndexingStatus/No"}],"http://purl.org/ASN/schema/core/statementLabel":[{"@language":"en-au","@value":"Organising Idea"}],"http://purl.org/ASN/schema/core/statementNotation":[{"@language":"en-au","@value":"A_TSICP2"}],"http://purl.org/dc/terms/description":[{"@language":"en-au","@value":"<p>The occupation and colonisation of Australia by the British, under the now overturned doctrine of <em>terra nullius</em>, were experienced by First Nations Australians as an invasion that denied their occupation of, and connection to, Country/Place.</p>"}],"http://purl.org/dc/terms/modified":[{"@type":"http://www.w3.org/2001/XMLSchema#dateTime","@value":"2021-09-03T15:54:30.000Z"}],"http://purl.org/dc/terms/title":[{"@language":"en-au","@value":"<p>The occupation and colonisation of Australia by the British, under the now overturned doctrine of <em>terra nullius</em>, were experienced by First Nations Australians as an invasion that denied their occupation of, and connection to, Country/Place.</p>"}],"http://purl.org/gem/qualifiers/isChildOf":[{"@id":"http://vocabulary.curriculum.edu.au/MRAC/2024/04/CCP/A_TSI/14284281-58d4-43c6-9195-ae4a00a59cdf"}],"http://www.w3.org/2004/02/skos/core#prefLabel":[{"@language":"en-au","@value":"A_TSICP2"}]},{"@id":"http://vocabulary.curriculum.edu.au/MRAC/2024/04/CCP/A_TSI/940cfe04-48e5-475b-a682-94cb6c6b2235","@type":["http://purl.org/ASN/schema/core/Statement","http://www.w3.org/2004/02/skos/core#Concept"],"http://purl.org/ASN/schema/core/authorityStatus":[{"@id":"http://purl.org/ASN/scheme/ASNAuthorityStatus/Original"}],"http://purl.org/ASN/schema/core/conceptTerm":[{"@language":"en-au","@value":"SCIENCE_TEACHER_BACKGROUND_INFORMATION"}],"http://purl.org/ASN/schema/core/indexingStatus":[{"@id":"http://purl.org/ASN/scheme/ASNIndexingStatus/No"}],"http://purl.org/ASN/schema/core/statementLabel":[{"@language":"en-au","@value":"Organising Idea"}],"http://purl.org/ASN/schema/core/statementNotation":[{"@language":"en-au","@value":"A_TSIP1"}],"http://purl.org/dc/terms/description":[{"@language":"en-au","@value":"Australia has 2 distinct First Nations Peoples; each encompasses a diversity of nations across Australia. Aboriginal Peoples are the first peoples of Australia and have occupied the Australian continent for more than 60,000 years. Torres Strait Islander Peoples are the First Nations Peoples of the Torres Strait and have occupied the region for over 4,000 years. "}],"http://purl.org/dc/terms/modified":[{"@type":"http://www.w3.org/2001/XMLSchema#dateTime","@value":"2021-09-03T15:54:30.000Z"}],"http://purl.org/dc/terms/title":[{"@language":"en-au","@value":"Australia has 2 distinct First Nations Peoples; each encompasses a diversity of nations across Australia. Aboriginal Peoples are the first peoples of Australia and have occupied the Australian continent for more than 60,000 years. Torres Strait Islander Peoples are the First Nations Peoples of the Torres Strait and have occupied the region for over 4,000 years. "}],"http://purl.org/gem/qualifiers/isChildOf":[{"@id":"http://vocabulary.curriculum.edu.au/MRAC/2024/04/CCP/A_TSI/48c4c1a1-d829-4664-8065-81098c789148"}],"http://www.w3.org/2004/02/skos/core#prefLabel":[{"@language":"en-au","@value":"A_TSIP1"}]},{"@id":"http://vocabulary.curriculum.edu.au/MRAC/2024/04/CCP/A_TSI/958b0a03-070f-4f61-af60-36b5172ae4f2","@type":["http://purl.org/ASN/schema/core/Statement","http://www.w3.org/2004/02/skos/core#Concept"],"http://purl.org/ASN/schema/core/authorityStatus":[{"@id":"http://purl.org/ASN/scheme/ASNAuthorityStatus/Original"}],"http://purl.org/ASN/schema/core/conceptTerm":[{"@language":"en-au","@value":"SCIENCE_TEACHER_BACKGROUND_INFORMATION"}],"http://purl.org/ASN/schema/core/indexingStatus":[{"@id":"http://purl.org/ASN/scheme/ASNIndexingStatus/No"}],"http://purl.org/ASN/schema/core/statementLabel":[{"@language":"en-au","@value":"Organising Idea"}],"http://purl.org/ASN/schema/core/statementNotation":[{"@language":"en-au","@value":"A_TSIP2"}],"http://purl.org/dc/terms/description":[{"@language":"en-au","@value":"First Nations Australians have sophisticated political, economic and social organisation systems, which include family and kinship structures, laws, traditions, customs, land tenure systems, and protocols for strong governance and authority."}],"http://purl.org/dc/terms/modified":[{"@type":"http://www.w3.org/2001/XMLSchema#dateTime","@value":"2021-09-03T15:54:30.000Z"}],"http://purl.org/dc/terms/title":[{"@language":"en-au","@value":"First Nations Australians have sophisticated political, economic and social organisation systems, which include family and kinship structures, laws, traditions, customs, land tenure systems, and protocols for strong governance and authority."}],"http://purl.org/gem/qualifiers/isChildOf":[{"@id":"http://vocabulary.curriculum.edu.au/MRAC/2024/04/CCP/A_TSI/48c4c1a1-d829-4664-8065-81098c789148"}],"http://www.w3.org/2004/02/skos/core#prefLabel":[{"@language":"en-au","@value":"A_TSIP2"}]},{"@id":"http://vocabulary.curriculum.edu.au/MRAC/2024/04/CCP/A_TSI/a6a830c6-102b-4325-8c1e-7dd3552b983c","@type":["http://purl.org/ASN/schema/core/Statement","http://www.w3.org/2004/02/skos/core#Concept"],"http://purl.org/ASN/schema/core/authorityStatus":[{"@id":"http://purl.org/ASN/scheme/ASNAuthorityStatus/Original"}],"http://purl.org/ASN/schema/core/indexingStatus":[{"@id":"http://purl.org/ASN/scheme/ASNIndexingStatus/No"}],"http://purl.org/ASN/schema/core/listID":[{"@language":"en-au","@value":"2"}],"http://purl.org/ASN/schema/core/statementLabel":[{"@language":"en-au","@value":"Set of organising ideas"}],"http://purl.org/ASN/schema/core/statementNotation":[{"@language":"en-au","@value":"A_TSIC"}],"http://purl.org/dc/terms/description":[{"@language":"en-au","@value":"These organising ideas examine the cultural diversity of the First Peoples of Australia and the First Nations Peoples of the Torres Strait, and recognise Australian First Nations Peoples as belonging to the world’s oldest continuous cultures. "}],"http://purl.org/dc/terms/modified":[{"@type":"http://www.w3.org/2001/XMLSchema#dateTime","@value":"2021-09-03T15:54:30.000Z"}],"http://purl.org/dc/terms/title":[{"@language":"en-au","@value":"Culture"}],"http://purl.org/gem/qualifiers/hasChild":[{"@id":"http://vocabulary.curriculum.edu.au/MRAC/2024/04/CCP/A_TSI/ccb438a5-f1c9-4cde-b65d-4629843294e4"},{"@id":"http://vocabulary.curriculum.edu.au/MRAC/2024/04/CCP/A_TSI/646e98e2-6711-4331-a503-d664524421bf"},{"@id":"http://vocabulary.curriculum.edu.au/MRAC/2024/04/CCP/A_TSI/119a4f3c-5dd2-4248-b35c-9310080b8f8b"}],"http://purl.org/gem/qualifiers/isChildOf":[{"@id":"http://vocabulary.curriculum.edu.au/MRAC/2024/04/CCP/A_TSI/f84c84ea-02a6-42c2-8c97-66f527855587"}],"http://www.w3.org/2004/02/skos/core#prefLabel":[{"@language":"en-au","@value":"A_TSIC"}]},{"@id":"http://vocabulary.curriculum.edu.au/MRAC/2024/04/CCP/A_TSI/ccb438a5-f1c9-4cde-b65d-4629843294e4","@type":["http://purl.org/ASN/schema/core/Statement","http://www.w3.org/2004/02/skos/core#Concept"],"http://purl.org/ASN/schema/core/authorityStatus":[{"@id":"http://purl.org/ASN/scheme/ASNAuthorityStatus/Original"}],"http://purl.org/ASN/schema/core/conceptTerm":[{"@language":"en-au","@value":"SCIENCE_TEACHER_BACKGROUND_INFORMATION"}],"http://purl.org/ASN/schema/core/indexingStatus":[{"@id":"http://purl.org/ASN/scheme/ASNIndexingStatus/No"}],"http://purl.org/ASN/schema/core/statementLabel":[{"@language":"en-au","@value":"Organising Idea"}],"http://purl.org/ASN/schema/core/statementNotation":[{"@language":"en-au","@value":"A_TSIC1"}],"http://purl.org/dc/terms/description":[{"@language":"en-au","@value":"First Nations Australian societies are diverse and have distinct cultural expressions such as language, customs and beliefs. As First Nations Peoples of Australia, they have the right to maintain, control, protect and develop their cultural expressions, while also maintaining the right to control, protect and develop culture as Indigenous Cultural and Intellectual Property."}],"http://purl.org/dc/terms/modified":[{"@type":"http://www.w3.org/2001/XMLSchema#dateTime","@value":"2021-09-03T15:54:30.000Z"}],"http://purl.org/dc/terms/title":[{"@language":"en-au","@value":"First Nations Australian societies are diverse and have distinct cultural expressions such as language, customs and beliefs. As First Nations Peoples of Australia, they have the right to maintain, control, protect and develop their cultural expressions, while also maintaining the right to control, protect and develop culture as Indigenous Cultural and Intellectual Property."}],"http://purl.org/gem/qualifiers/isChildOf":[{"@id":"http://vocabulary.curriculum.edu.au/MRAC/2024/04/CCP/A_TSI/a6a830c6-102b-4325-8c1e-7dd3552b983c"}],"http://www.w3.org/2004/02/skos/core#prefLabel":[{"@language":"en-au","@value":"A_TSIC1"}]},{"@id":"http://vocabulary.curriculum.edu.au/MRAC/2024/04/CCP/A_TSI/d7a08fd7-9924-4e01-875f-6ae08cc4674d","@type":["http://purl.org/ASN/schema/core/Statement","http://www.w3.org/2004/02/skos/core#Concept"],"http://purl.org/ASN/schema/core/authorityStatus":[{"@id":"http://purl.org/ASN/scheme/ASNAuthorityStatus/Original"}],"http://purl.org/ASN/schema/core/conceptTerm":[{"@language":"en-au","@value":"SCIENCE_TEACHER_BACKGROUND_INFORMATION"}],"http://purl.org/ASN/schema/core/indexingStatus":[{"@id":"http://purl.org/ASN/scheme/ASNIndexingStatus/No"}],"http://purl.org/ASN/schema/core/statementLabel":[{"@language":"en-au","@value":"Organising Idea"}],"http://purl.org/ASN/schema/core/statementNotation":[{"@language":"en-au","@value":"A_TSICP3"}],"http://purl.org/dc/terms/description":[{"@language":"en-au","@value":"<p>The First Peoples of Australia are the Traditional Owners of Country/Place, protected in Australian Law by the <em>Native Title Act 1993</em> which recognises pre-existing sovereignty, continuing systems of law and customs, and connection to Country/Place. This recognised legal right provides for economic sustainability and a voice into the development and management of Country/Place.</p>"}],"http://purl.org/dc/terms/modified":[{"@type":"http://www.w3.org/2001/XMLSchema#dateTime","@value":"2021-09-03T15:54:30.000Z"}],"http://purl.org/dc/terms/title":[{"@language":"en-au","@value":"<p>The First Peoples of Australia are the Traditional Owners of Country/Place, protected in Australian Law by the <em>Native Title Act 1993</em> which recognises pre-existing sovereignty, continuing systems of law and customs, and connection to Country/Place. This recognised legal right provides for economic sustainability and a voice into the development and management of Country/Place.</p>"}],"http://purl.org/gem/qualifiers/isChildOf":[{"@id":"http://vocabulary.curriculum.edu.au/MRAC/2024/04/CCP/A_TSI/14284281-58d4-43c6-9195-ae4a00a59cdf"}],"http://www.w3.org/2004/02/skos/core#prefLabel":[{"@language":"en-au","@value":"A_TSICP3"}]},{"@id":"http://vocabulary.curriculum.edu.au/MRAC/2024/04/CCP/A_TSI/f84c84ea-02a6-42c2-8c97-66f527855587","@type":["http://purl.org/ASN/schema/core/Statement","http://www.w3.org/2004/02/skos/core#Concept"],"http://purl.org/ASN/schema/core/authorityStatus":[{"@id":"http://purl.org/ASN/scheme/ASNAuthorityStatus/Original"}],"http://purl.org/ASN/schema/core/indexingStatus":[{"@id":"http://purl.org/ASN/scheme/ASNIndexingStatus/No"}],"http://purl.org/ASN/schema/core/statementLabel":[{"@language":"en-au","@value":"Cross-Curriculum Priority"}],"http://purl.org/ASN/schema/core/statementNotation":[{"@language":"en-au","@value":"A_TSI"}],"http://purl.org/dc/terms/description":[{"@language":"en-au","@value":"<p>The Aboriginal and Torres Strait Islander Histories and Cultures cross-curriculum priority provides opportunities for all students to deepen their knowledge of Australia by learning about the world’s oldest continuous living cultures.</p><p>The Aboriginal and Torres Strait Islander Histories and Cultures cross-curriculum priority engages with Australian First Nations Peoples’ knowledges, experiences, values and perspectives. Through the Australian Curriculum, students learn that contemporary First Nations Australian communities are strong, resilient, rich and diverse. It also allows Aboriginal and Torres Strait Islander students to see themselves and their cultures reflected in the curriculum.</p>"}],"http://purl.org/dc/terms/modified":[{"@type":"http://www.w3.org/2001/XMLSchema#dateTime","@value":"2021-09-03T15:54:30.000Z"}],"http://purl.org/dc/terms/title":[{"@language":"en-au","@value":"Aboriginal and Torres Strait Islander Histories and Cultures"}],"http://purl.org/gem/qualifiers/hasChild":[{"@id":"http://vocabulary.curriculum.edu.au/MRAC/2024/04/CCP/A_TSI/14284281-58d4-43c6-9195-ae4a00a59cdf"},{"@id":"http://vocabulary.curriculum.edu.au/MRAC/2024/04/CCP/A_TSI/a6a830c6-102b-4325-8c1e-7dd3552b983c"},{"@id":"http://vocabulary.curriculum.edu.au/MRAC/2024/04/CCP/A_TSI/48c4c1a1-d829-4664-8065-81098c789148"}],"http://purl.org/gem/qualifiers/isChildOf":[{"@id":"http://vocabulary.curriculum.edu.au/MRAC/2024/04/CCP/5c04d332-8412-4e26-bd57-425883be63aa"}],"http://www.w3.org/2004/02/skos/core#prefLabel":[{"@language":"en-au","@value":"A_TSI"}]},{"@id":"http://vocabulary.curriculum.edu.au/MRAC/2024/04/CCP/A_TSI/f8d4a191-c790-4ff8-b203-2427a21d0b9a","@type":["http://purl.org/ASN/schema/core/Statement","http://www.w3.org/2004/02/skos/core#Concept"],"http://purl.org/ASN/schema/core/authorityStatus":[{"@id":"http://purl.org/ASN/scheme/ASNAuthorityStatus/Original"}],"http://purl.org/ASN/schema/core/conceptTerm":[{"@language":"en-au","@value":"SCIENCE_TEACHER_BACKGROUND_INFORMATION"}],"http://purl.org/ASN/schema/core/indexingStatus":[{"@id":"http://purl.org/ASN/scheme/ASNIndexingStatus/No"}],"http://purl.org/ASN/schema/core/statementLabel":[{"@language":"en-au","@value":"Organising Idea"}],"http://purl.org/ASN/schema/core/statementNotation":[{"@language":"en-au","@value":"A_TSICP1"}],"http://purl.org/dc/terms/description":[{"@language":"en-au","@value":"First Nations communities of Australia maintain a deep connection to, and responsibility for, Country/Place and have holistic values and belief systems that are connected to the land, sea, sky and waterways."}],"http://purl.org/dc/terms/modified":[{"@type":"http://www.w3.org/2001/XMLSchema#dateTime","@value":"2021-09-03T15:54:30.000Z"}],"http://purl.org/dc/terms/title":[{"@language":"en-au","@value":"First Nations communities of Australia maintain a deep connection to, and responsibility for, Country/Place and have holistic values and belief systems that are connected to the land, sea, sky and waterways."}],"http://purl.org/gem/qualifiers/isChildOf":[{"@id":"http://vocabulary.curriculum.edu.au/MRAC/2024/04/CCP/A_TSI/14284281-58d4-43c6-9195-ae4a00a59cdf"}],"http://www.w3.org/2004/02/skos/core#prefLabel":[{"@language":"en-au","@value":"A_TSICP1"}]},{"@id":"http://www.w3.org/2004/02/skos/core","http://purl.org/dc/terms/contributor":[{"@id":"http://vocabulary.curriculum.edu.au/user/srichardson"}]},{"@id":"http://www.w3.org/2008/05/skos-xl","http://purl.org/dc/terms/contributor":[{"@id":"http://vocabulary.curriculum.edu.au/user/srichardson"}]}],"@id":"http://vocabulary.curriculum.edu.au/MRAC/2024/04/CCP/A_TSI/thesaurus"}]